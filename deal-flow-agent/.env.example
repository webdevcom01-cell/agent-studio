# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension
DATABASE_URL=postgresql+asyncpg://dealflow:dealflow_secret@localhost:5433/dealflow

# ── AI Providers (at least one required for live mode) ────────────────────
# Without these keys the system runs in demo mode (rich mock data)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── External Integrations (optional) ─────────────────────────────────────
# LinkedIn Marketing API
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Crunchbase Basic API
CRUNCHBASE_API_KEY=

# ── AI Config ─────────────────────────────────────────────────────────────
AI_MODEL=claude-opus-4-6
EMBEDDING_DIMENSION=1536
