{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/error.tsx",
    "src/app/**/loading.tsx",
    "src/app/**/not-found.tsx",
    "src/app/**/route.ts",
    "src/app/**/route.tsx",
    "src/middleware.ts",
    "src/instrumentation.ts",
    "public/embed.js",
    "prisma/seed.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "!src/generated/**"
  ],
  "ignore": [
    "src/generated/**",
    "**/*.d.ts",
    "test-*.ts"
  ],
  "ignoreDependencies": [
    "prisma",
    "@prisma/client",
    "@prisma/adapter-pg",
    "tsx",
    "postcss",
    "@tailwindcss/postcss",
    "jsdom",
    "@playwright/test",
    "@playwright/mcp",
    "@testing-library/jest-dom",
    "@testing-library/react"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn",
    "classMembers": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "optionalPeerDependencies": "off",
    "unlisted": "warn",
    "unresolved": "warn"
  }
}
