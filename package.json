{
  "name": "agent-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && (test -f .git/HEAD || (mkdir -p .git && echo \"ref: refs/heads/main\" > .git/HEAD)) && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:load": "k6 run load-tests/agent-studio.js",
    "changelog": "git log --pretty=format:'- %s (%ad)' --date=short >> CHANGELOG.md",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "mcp:playwright": "npx @playwright/mcp --port 3100",
    "worker": "tsx src/lib/queue/worker.ts",
    "precheck": "bash scripts/pre-push-check.sh",
    "precheck:file": "bash scripts/pre-push-check.sh",
    "knip": "npx knip@5",
    "knip:fix": "npx knip@5 --fix",
    "knip:ci": "npx knip@5 --reporter compact --no-exit-code"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.80",
