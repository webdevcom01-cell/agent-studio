{
  "name": "agent-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && (test -f .git/HEAD || (mkdir -p .git && echo \"ref: refs/heads/main\" > .git/HEAD)) && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "mcp:playwright": "npx @playwright/mcp --port 3100",
    "precheck": "bash scripts/pre-push-check.sh",
    "precheck:file": "bash scripts/pre-push-check.sh",
    "knip": "npx knip@5",
    "knip:fix": "npx knip@5 --fix",
    "knip:ci": "npx knip@5 --reporter compact --no-exit-code"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@deepgram/sdk": "^5.0.0",
    "@fal-ai/client": "^1.9.5",
    "@prisma/adapter-pg": "^6.9.0",
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^9.47.1",
    "@tavily/core": "^0.7.2",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.116",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.72.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compromise": "^14.15.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^2.60.0",
    "elevenlabs": "^1.59.0",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.513.0",
    "mammoth": "^1.12.0",
    "mysql2": "^3.20.0",
    "next": "15.5.14",
    "next-auth": "5.0.0-beta.30",
    "pdf-parse": "^1.1.1",
    "pg": "^8.18.0",
    "prisma": "^6.19.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "resend": "^4.8.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": ">=0.8.12",
      "lodash": ">=4.18.0",
      "picomatch": ">=4.0.4",
      "effect": ">=3.20.0"
    }
  }
}
