      {"name": "Compliance", "duration_min": 45},
      {"name": "Operational/Knowledge", "duration_min": 40},
      {"name": "Reporting", "duration_min": 15}
    ]
  },

  "database_schema": {
    "agent_audits": {
      "description": "Monthly audit snapshots per agent",
      "columns": 27,
      "key_fields": [
        "agent_id (UUID, FK to agents)",
        "audit_date (DATE)",
        "p50/p95/p99_latency_ms (FLOAT)",
        "error_rate, timeout_rate (FLOAT)",
        "accuracy_score, hallucination_rate (FLOAT)",
        "citation_coverage, citation_accuracy (FLOAT)",
        "uptime_pct, cpu_usage_pct (FLOAT)",
        "knowledge_base_documents, knowledge_base_chunks (INT)",
        "dau (INT), satisfaction_rate (FLOAT)",
        "total_tokens (BIGINT), cost_usd (FLOAT)",
        "report (JSON)"
      ],
      "indexes": [
        "idx_agent_audits_agentId_date on (agent_id, audit_date DESC)"
      ],
      "retention": "24 months"
    },
    "audit_metrics": {
      "description": "Time-series metric details",
      "columns": 5,
      "key_fields": [
        "audit_id (UUID, FK to agent_audits)",
        "metric_name (VARCHAR)",
        "metric_value (FLOAT)",
        "dimension (VARCHAR)",
        "recorded_at (TIMESTAMPTZ)"
      ],
      "indexes": [
        "idx_audit_metrics_auditId on (audit_id)"
      ]
    }
  },

