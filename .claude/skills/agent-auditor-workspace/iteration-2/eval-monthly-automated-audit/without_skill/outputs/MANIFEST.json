  "execution_schedule": {
    "frequency": "monthly",
    "cron_expression": "0 2 * * 0",
    "description": "First Sunday of month at 02:00 UTC",
    "timezone": "UTC",
    "duration_minutes": "120-240",
    "phases": [
      {"name": "Preparation", "duration_min": 15},
      {"name": "Performance", "duration_min": 30},
