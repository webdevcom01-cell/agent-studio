generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  agents        Agent[]
  accounts      Account[]
  sessions      Session[]
  mcpServers    MCPServer[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id            String         @id @default(cuid())
  name          String
  description   String?
  systemPrompt  String?        @db.Text
  model         String         @default("gpt-4o-mini")
  temperature   Float          @default(0.7)
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  flow          Flow?
  knowledgeBase KnowledgeBase?
  conversations   Conversation[]
  analyticsEvents AnalyticsEvent[]
  mcpServers      AgentMCPServer[]
  callerCallLogs    AgentCallLog[]          @relation("CallerCallLogs")
  calleeCallLogs    AgentCallLog[]          @relation("CalleeCallLogs")
  agentCard         AgentCard?
  approvalRequests  HumanApprovalRequest[]
  deployments       FlowDeployment[]

  @@index([userId])
  @@index([userId, updatedAt])
}

model Flow {
  id              String        @id @default(cuid())
  name            String        @default("Main Flow")
  content         Json          @default("{\"nodes\":[],\"edges\":[],\"variables\":[]}")
  activeVersionId String?
  agentId         String        @unique
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versions        FlowVersion[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model KnowledgeBase {
  id        String     @id @default(cuid())
  name      String     @default("Knowledge Base")
  agentId   String     @unique
  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sources   KBSource[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum KBSourceType {
  FILE
  URL
  SITEMAP
  TEXT
}

enum KBSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model KBSource {
  id              String         @id @default(cuid())
  type            KBSourceType
  name            String
  url             String?
  rawContent      String?        @db.Text
  status          KBSourceStatus @default(PENDING)
  errorMsg        String?
  charCount       Int            @default(0)
  retryCount      Int            @default(0)
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          KBChunk[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([knowledgeBaseId])
  @@index([knowledgeBaseId, status])
}

model KBChunk {
  id        String                       @id @default(cuid())
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")
  tokens    Int
  metadata  Json?
  sourceId  String
  source    KBSource                     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt DateTime                     @default(now())

  @@index([sourceId])
}

enum AnalyticsEventType {
  CHAT_RESPONSE
  KB_SEARCH
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  type      AnalyticsEventType
  agentId   String
  agent     Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())

  @@index([agentId])
  @@index([type, createdAt])
  @@index([createdAt])
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Conversation {
  id              String             @id @default(cuid())
  status          ConversationStatus @default(ACTIVE)
  currentNodeId   String?
  variables       Json               @default("{}")
  agentId         String
  agent           Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId   String?
  flowVersion     FlowVersion?       @relation(fields: [flowVersionId], references: [id])
  messages        Message[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([agentId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String       @db.Text
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

enum MCPTransport {
  STREAMABLE_HTTP
  SSE
}

model MCPServer {
  id         String         @id @default(cuid())
  name       String
  url        String
  transport  MCPTransport   @default(STREAMABLE_HTTP)
  headers    Json?
  toolsCache Json?
  enabled    Boolean        @default(true)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents     AgentMCPServer[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
}

model AgentMCPServer {
  id           String    @id @default(cuid())
  agentId      String
  mcpServerId  String
  enabledTools Json?
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mcpServer    MCPServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@unique([agentId, mcpServerId])
  @@index([agentId])
  @@index([mcpServerId])
}

// ─── Flow Versioning ─────────────────────────────────────────────────────────

enum FlowVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FlowVersion {
  id             String            @id @default(cuid())
  flowId         String
  flow           Flow              @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version        Int
  label          String?
  content        Json
  status         FlowVersionStatus @default(DRAFT)
  changesSummary Json?
  createdById    String?
  createdAt      DateTime          @default(now())

  deployments    FlowDeployment[]
  conversations  Conversation[]

  @@unique([flowId, version])
  @@index([flowId])
  @@index([flowId, status])
  @@index([createdAt])
}

model FlowDeployment {
  id              String      @id @default(cuid())
  agentId         String
  agent           Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId   String
  flowVersion     FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)
  deployedById    String?
  note            String?
  createdAt       DateTime    @default(now())

  @@index([agentId])
  @@index([flowVersionId])
  @@index([createdAt])
}

// ─── A2A Communication ────────────────────────────────────────────────────────

model AgentCard {
  id        String   @id @default(cuid())
  agentId   String   @unique
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isPublic  Boolean  @default(false)
  skills    Json
  updatedAt DateTime @updatedAt
}

model HumanApprovalRequest {
  id          String    @id @default(cuid())
  executionId String
  agentId     String
  userId      String
  prompt      String    @db.Text
  contextData Json?
  status      String    @default("pending")
  response    String?   @db.Text
  expiresAt   DateTime
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([userId, status])
  @@index([executionId])
}

enum A2ATaskStatus {
  SUBMITTED
  WORKING
  INPUT_REQUIRED
  COMPLETED
  FAILED
}

model AgentCallLog {
  id            String        @id @default(cuid())

  traceId       String
  spanId        String        @unique
  parentSpanId  String?

  callerAgentId String
  calleeAgentId String?
  externalUrl   String?

  taskId        String        @unique
  status        A2ATaskStatus @default(SUBMITTED)

  inputParts    Json
  outputParts   Json?
  errorMessage  String?

  durationMs    Int?
  tokensUsed    Int?
  estimatedCostUsd Decimal?   @db.Decimal(10, 6)

  executionId   String?
  depth         Int           @default(0)
  isParallel    Boolean       @default(false)

  createdAt     DateTime      @default(now())
  completedAt   DateTime?

  callerAgent   Agent         @relation("CallerCallLogs", fields: [callerAgentId], references: [id], onDelete: Cascade)
  calleeAgent   Agent?        @relation("CalleeCallLogs", fields: [calleeAgentId], references: [id], onDelete: Cascade)

  @@index([callerAgentId])
  @@index([calleeAgentId])
  @@index([traceId])
  @@index([createdAt])
}
