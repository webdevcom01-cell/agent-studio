generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletionRequestedAt DateTime?
  deletionScheduledFor DateTime?
  agents           Agent[]
  accounts         Account[]
  sessions         Session[]
  mcpServers       MCPServer[]
  cliGenerations   CLIGeneration[]
  googleOAuthTokens GoogleOAuthToken[]
  orgMemberships   OrganizationMember[]
  apiKeys          ApiKey[]
}

// ---------------------------------------------------------------------------
// API Key Authentication — programmatic access (2026 enterprise standard)
// Keys are stored as SHA-256 hashes — plaintext is never persisted.
// Format: as_live_<32 random bytes base64url>
// ---------------------------------------------------------------------------

model ApiKey {
  id          String    @id @default(cuid())
  /// SHA-256 hash of the raw key — never store plaintext
  keyHash     String    @unique
  /// First 8 chars of the raw key for identification in UI (e.g. "as_live_")
  keyPrefix   String
  name        String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Array of scope strings, e.g. ["agents:read","agents:write","flows:execute"]
  scopes      String[]  @default([])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  /// Set when key is revoked — soft delete
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([userId])
  @@index([userId, revokedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  /// Whether token fields (access_token, refresh_token, id_token) are AES-256-GCM encrypted.
  /// false = legacy plaintext, true = encrypted. Used for zero-downtime migration.
  tokensEncrypted   Boolean @default(false)

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])

  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id            String         @id @default(cuid())
  name          String
  description   String?
  systemPrompt  String?        @db.Text
  model         String         @default("gpt-4o-mini")
  temperature   Float          @default(0.7)
  category      String?
  tags          String[]       @default([])
  isPublic      Boolean        @default(false)
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?  @relation("OrgAgents", fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  flow          Flow?
  knowledgeBase KnowledgeBase?
  conversations   Conversation[]
  analyticsEvents AnalyticsEvent[]
  mcpServers      AgentMCPServer[]
  callerCallLogs    AgentCallLog[]          @relation("CallerCallLogs")
  calleeCallLogs    AgentCallLog[]          @relation("CalleeCallLogs")
  agentCard         AgentCard?
  approvalRequests  HumanApprovalRequest[]
  deployments       FlowDeployment[]
  memories          AgentMemory[]
  evalSuites        EvalSuite[]
  schedules         FlowSchedule[]
  webhooks          WebhookConfig[]
  executions        AgentExecution[]
  skillPermissions  AgentSkillPermission[]
  instincts         Instinct[]
  eccEnabled        Boolean        @default(false)
  flowTraces        FlowTrace[]
  /// Task 3.2 — Per-Agent Timeout Profiles.
  /// Expected execution duration (seconds) used by agent-as-tool orchestration.
  /// Valid range: 5–600 s.  null = use AGENT_TIMEOUT_PROFILES name-pattern.
  expectedDurationSeconds Int?

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([organizationId])
  @@index([category])
  @@index([isPublic, updatedAt])
}

model Flow {
  id              String        @id @default(cuid())
  name            String        @default("Main Flow")
  content         Json          @default("{\"nodes\":[],\"edges\":[],\"variables\":[]}")
  activeVersionId String?
  agentId         String        @unique
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versions        FlowVersion[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model KnowledgeBase {
  id        String     @id @default(cuid())
  name      String     @default("Knowledge Base")
  agentId   String     @unique
  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sources   KBSource[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  chunkingStrategy    Json?
  embeddingModel      String    @default("text-embedding-3-small")
  embeddingDimension  Int       @default(1536)
  retrievalMode       String    @default("hybrid")
  rerankingModel      String    @default("llm-rubric")
  queryTransform      String    @default("none")
  searchTopK          Int       @default(5)
  searchThreshold     Float     @default(0.25)
  hybridAlpha         Float     @default(0.7)
  maxChunks           Int       @default(500)
  contextOrdering         String    @default("relevance")
  migrationStatus         String?
  processingProgress      Json?
  // Anthropic Contextual Retrieval — prepend LLM-generated context to each chunk during ingest
  contextualEnrichment    Boolean   @default(false)
}

enum KBSourceType {
  FILE
  URL
  SITEMAP
  TEXT
}

enum KBSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model KBSource {
  id              String         @id @default(cuid())
  type            KBSourceType
  name            String
  url             String?
  rawContent      String?        @db.Text
  status          KBSourceStatus @default(PENDING)
  errorMsg        String?
  charCount       Int            @default(0)
  retryCount      Int            @default(0)
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          KBChunk[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customMetadata        Json?
  language              String?
  expiresAt             DateTime?
  reingestionSchedule   String?
  reingestionEnabled    Boolean   @default(false)
  lastIngestedAt        DateTime?
  contentHash           String?
  processingProgress    Json?

  @@index([knowledgeBaseId])
  @@index([knowledgeBaseId, status])
}

model KBChunk {
  id        String                       @id @default(cuid())
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")
  tokens    Int
  metadata  Json?
  sourceId  String
  source    KBSource                     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt DateTime                     @default(now())

  contentHash      String?
  lastRetrievedAt  DateTime?
  retrievalCount   Int       @default(0)

  @@index([sourceId])
  @@index([contentHash])
  @@index([lastRetrievedAt])
}

enum AnalyticsEventType {
  CHAT_RESPONSE
  KB_SEARCH
  TOOL_CALL
  AGENT_CALL
  ERROR
  FLOW_EXECUTION
  SCHEDULE_EXECUTION
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  type      AnalyticsEventType
  agentId   String
  agent     Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())

  // AI/LLM metrics
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  costUsd        Decimal?   @db.Decimal(10, 6)

  // Performance metrics
  durationMs     Int?
  ttfbMs         Int?       // Time to first byte/token

  // Session tracking
  sessionId      String?
  conversationId String?

  @@index([agentId])
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([sessionId])
  @@index([model, createdAt])
  @@index([agentId, type, createdAt])
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Conversation {
  id              String             @id @default(cuid())
  status          ConversationStatus @default(ACTIVE)
  currentNodeId   String?
  variables       Json               @default("{}")
  agentId         String
  agent           Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId   String?
  flowVersion     FlowVersion?       @relation(fields: [flowVersionId], references: [id])
  messages        Message[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([agentId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String       @db.Text
  citations      Json?
  metadata       Json?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

enum MCPTransport {
  STREAMABLE_HTTP
  SSE
}

model MCPServer {
  id         String         @id @default(cuid())
  name       String
  url        String
  transport  MCPTransport   @default(STREAMABLE_HTTP)
  serverType String         @default("external")
  cliConfig  Json?
  headers    Json?
  toolsCache Json?
  enabled    Boolean        @default(true)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents         AgentMCPServer[]
  cliGenerations CLIGeneration[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
}

model AgentMCPServer {
  id           String    @id @default(cuid())
  agentId      String
  mcpServerId  String
  enabledTools Json?
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mcpServer    MCPServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@unique([agentId, mcpServerId])
  @@index([agentId])
  @@index([mcpServerId])
}

// ─── Google Workspace OAuth ───────────────────────────────────────────────────

/**
 * Stores Google OAuth tokens for per-user Google Workspace access.
 * Used by the internal MCP proxy at /api/mcp/proxy/google-workspace/[id].
 * Separate from NextAuth Account tokens — these carry Calendar + Gmail scopes.
 */
model GoogleOAuthToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// The Google account email address
  email        String
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  /// When the current access token expires (null = unknown)
  expiresAt    DateTime?
  /// Space-separated OAuth scopes granted
  scopes       String    @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// Prevent duplicate connections for the same user+email combination
  @@unique([userId, email])
  @@index([userId])
}

// ─── Flow Versioning ─────────────────────────────────────────────────────────

enum FlowVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FlowVersion {
  id             String            @id @default(cuid())
  flowId         String
  flow           Flow              @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version        Int
  label          String?
  content        Json
  status         FlowVersionStatus @default(DRAFT)
  changesSummary Json?
  createdById    String?
  createdAt      DateTime          @default(now())

  deployments    FlowDeployment[]
  conversations  Conversation[]

  @@unique([flowId, version])
  @@index([flowId])
  @@index([flowId, status])
  @@index([createdAt])
}

model FlowDeployment {
  id              String      @id @default(cuid())
  agentId         String
  agent           Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId   String
  flowVersion     FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)
  deployedById    String?
  note            String?
  createdAt       DateTime    @default(now())

  @@index([agentId])
  @@index([flowVersionId])
  @@index([createdAt])
}

// ─── A2A Communication ────────────────────────────────────────────────────────

model AgentCard {
  id        String   @id @default(cuid())
  agentId   String   @unique
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isPublic  Boolean  @default(false)
  skills    Json
  updatedAt DateTime @updatedAt
}

model HumanApprovalRequest {
  id          String    @id @default(cuid())
  executionId String
  agentId     String
  userId      String?
  prompt      String    @db.Text
  contextData Json?
  status      String    @default("pending")
  response    String?   @db.Text
  expiresAt   DateTime
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([userId, status])
  @@index([executionId])
}

enum A2ATaskStatus {
  SUBMITTED
  WORKING
  INPUT_REQUIRED
  COMPLETED
  FAILED
}

model AgentCallLog {
  id            String        @id @default(cuid())

  traceId       String
  spanId        String        @unique
  parentSpanId  String?

  callerAgentId String
  calleeAgentId String?
  externalUrl   String?

  taskId        String        @unique
  status        A2ATaskStatus @default(SUBMITTED)

  inputParts    Json
  outputParts   Json?
  errorMessage  String?

  durationMs    Int?
  tokensUsed    Int?
  estimatedCostUsd Decimal?   @db.Decimal(10, 6)

  executionId      String?
  conversationId   String?
  depth            Int           @default(0)
  isParallel       Boolean       @default(false)

  createdAt     DateTime      @default(now())
  completedAt   DateTime?

  callerAgent   Agent         @relation("CallerCallLogs", fields: [callerAgentId], references: [id], onDelete: Cascade)
  calleeAgent   Agent?        @relation("CalleeCallLogs", fields: [calleeAgentId], references: [id], onDelete: Cascade)

  @@index([callerAgentId])
  @@index([calleeAgentId])
  @@index([traceId])
  @@index([conversationId])
  @@index([createdAt])
}

// ─── CLI Generation Pipeline ─────────────────────────────────────────────────

enum CLIGenerationStatus {
  PENDING
  ANALYZING
  DESIGNING
  IMPLEMENTING
  TESTING
  DOCUMENTING
  PUBLISHING
  COMPLETED
  FAILED
}

model CLIGeneration {
  id              String               @id @default(cuid())
  applicationName String
  /// Target language for the generated MCP bridge: "python" (FastMCP) or "typescript" (Node.js MCP SDK).
  target          String               @default("python")
  status          CLIGenerationStatus  @default(PENDING)
  currentPhase    Int                  @default(0)
  phases          Json                 @default("[]")
  cliConfig       Json?
  generatedFiles  Json?
  errorMessage    String?
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServerId     String?
  mcpServer       MCPServer?           @relation(fields: [mcpServerId], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
}

model AgentMemory {
  id          String   @id @default(cuid())
  agentId     String
  key         String
  value       Json
  category    String   @default("general")
  importance  Float    @default(0.5)
  embedding   Unsupported("vector(1536)")?
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accessedAt  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
  @@index([agentId, category])
  @@index([agentId, accessedAt])
}

// ─── Schedule Trigger (Cron) ─────────────────────────────────────────────────

enum ScheduleType {
  CRON
  INTERVAL
  MANUAL
}

enum ScheduledExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

/// Persistent schedule configuration for an agent's flow.
/// Created when a user configures a schedule_trigger node and activates it.
/// The Vercel Cron endpoint scans enabled schedules and triggers executions.
model FlowSchedule {
  id               String         @id @default(cuid())
  agentId          String
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)

  /// Schedule type: CRON (cron expression), INTERVAL (every N minutes), MANUAL (on-demand only)
  scheduleType     ScheduleType   @default(CRON)
  /// Standard cron expression (e.g., "0 9 * * 1" = every Monday at 9:00 AM)
  cronExpression   String?
  /// Interval in minutes (1–10080 = 1 week). Used when scheduleType = INTERVAL.
  intervalMinutes  Int?
  /// IANA timezone (e.g., "Europe/Belgrade", "America/New_York"). Cron evaluated in this TZ.
  timezone         String         @default("UTC")

  /// Whether this schedule is actively being triggered by the cron endpoint.
  enabled          Boolean        @default(true)
  /// Display label for the schedule (optional, user-defined).
  label            String?

  /// Computed by the scheduler after each execution — the next UTC time this should fire.
  nextRunAt        DateTime?
  /// Last time this schedule was successfully triggered.
  lastRunAt        DateTime?

  /// Consecutive failure count. If >= maxRetries, schedule is auto-disabled.
  failureCount     Int            @default(0)
  /// Maximum consecutive failures before auto-disable (0 = never auto-disable).
  maxRetries       Int            @default(3)

  /// Webhook URL for failure notifications (Slack, Discord, PagerDuty, etc.).
  /// POST with JSON payload on schedule failure or circuit breaker open.
  failureWebhookUrl String?

  /// Flow node ID that this schedule was synced from (set by deploy auto-sync).
  /// Null for schedules created manually via API.
  nodeId           String?

  executions       ScheduledExecution[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([agentId])
  @@index([enabled, nextRunAt])
  @@index([agentId, enabled])
  @@unique([agentId, nodeId])
}

/// Log of every scheduled execution attempt.
/// One row per trigger — tracks status, duration, token usage, and errors.
model ScheduledExecution {
  id               String                    @id @default(cuid())
  flowScheduleId   String
  flowSchedule     FlowSchedule              @relation(fields: [flowScheduleId], references: [id], onDelete: Cascade)

  status           ScheduledExecutionStatus  @default(PENDING)
  /// ISO timestamp when the cron endpoint picked up this schedule.
  triggeredAt      DateTime                  @default(now())
  /// ISO timestamp when execution completed (success or failure).
  completedAt      DateTime?
  /// Execution wall-clock time in milliseconds.
  durationMs       Int?

  /// Error message if status = FAILED.
  errorMessage     String?                   @db.Text
  /// Token usage breakdown: { inputTokens, outputTokens, totalTokens }
  tokenUsage       Json?
  /// Estimated cost in USD for this execution.
  costUsd          Decimal?                  @db.Decimal(10, 6)

  /// Idempotency key = "${flowScheduleId}_${triggerTimestamp}" — prevents duplicate runs.
  idempotencyKey   String                    @unique

  createdAt        DateTime                  @default(now())

  @@index([flowScheduleId])
  @@index([flowScheduleId, createdAt])
  @@index([status])
  @@index([triggeredAt])
}

// ─── Inbound Webhooks ─────────────────────────────────────────────────────────

enum WebhookExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  /// Duplicate idempotencyKey — skipped to prevent re-processing
  SKIPPED
}

/// Inbound webhook configuration for an agent.
/// Each config generates a unique public trigger URL that external systems
/// (Slack, GitHub, Stripe, etc.) can POST to in order to start a flow execution.
model WebhookConfig {
  id          String  @id @default(cuid())
  agentId     String
  agent       Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  /// Human-readable name for this webhook (e.g., "GitHub Push Events")
  name        String
  /// Optional description
  description String?

  /// HMAC-SHA256 signing secret — generated on creation, used to verify incoming requests.
  /// Encrypted at rest with AES-256-GCM when WEBHOOK_ENCRYPTION_KEY is configured.
  /// Rotatable via POST /rotate endpoint.
  secret      String

  /// Whether the secret field is AES-256-GCM encrypted (migration flag).
  /// false = legacy plaintext, true = encrypted. Used for zero-downtime migration.
  secretEncrypted Boolean @default(false)

  /// Whether this webhook is accepting incoming requests
  enabled     Boolean @default(true)

  /// JSONPath-style mappings from request body → flow variables
  /// e.g. [{ "jsonPath": "$.repository.name", "variableName": "repo_name", "type": "string" }]
  bodyMappings Json @default("[]")

  /// Header-to-variable mappings
  /// e.g. [{ "headerName": "X-GitHub-Event", "variableName": "github_event" }]
  headerMappings Json @default("[]")

  /// Event filter list — if non-empty, only events whose type matches one of the values
  /// will trigger the flow. Empty array means "accept all events".
  /// Event type is read from provider-specific headers (x-github-event, x-slack-event, etc.)
  /// or from the request body (e.g. Stripe uses $.type).
  eventFilters String[] @default([])

  /// Flow node ID that this config was synced from (set by deploy auto-sync).
  /// Null for webhooks created manually via API.
  nodeId String?

  /// Aggregate stats
  triggerCount Int      @default(0)
  failureCount Int      @default(0)
  lastTriggeredAt DateTime?

  executions  WebhookExecution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([agentId, enabled])
  @@unique([agentId, nodeId])
}

/// Log of every inbound webhook trigger attempt.
/// One row per incoming request — tracks status, idempotency, and execution result.
model WebhookExecution {
  id              String               @id @default(cuid())
  webhookConfigId String
  webhookConfig   WebhookConfig        @relation(fields: [webhookConfigId], references: [id], onDelete: Cascade)

  /// x-webhook-id header value (Standard Webhooks spec).
  /// Unique constraint enforces idempotency — same event ID is never processed twice.
  idempotencyKey  String               @unique

  status          WebhookExecutionStatus @default(PENDING)

  triggeredAt     DateTime             @default(now())
  completedAt     DateTime?
  /// Wall-clock execution time in milliseconds
  durationMs      Int?

  /// Source IP address of the caller
  sourceIp        String?
  /// Event type extracted from provider-specific header (X-GitHub-Event, Stripe event type, etc.)
  eventType       String?

  /// Conversation created by this execution (null if execution failed before context creation)
  conversationId  String?

  /// Error details if status = FAILED
  errorMessage    String?              @db.Text

  /// Raw request body stored for replay. Null for executions created before
  /// replay support was added, or if the body was empty.
  rawPayload      String?              @db.Text

  /// Sanitized request headers stored for replay (sensitive values redacted).
  /// Stored as a flat Record<string, string>.
  rawHeaders      Json?

  /// True when this execution was triggered by a Replay action (not a live inbound request).
  isReplay        Boolean              @default(false)

  /// If this is a replay, points to the original execution that was replayed.
  replayOf        String?

  /// Number of retry attempts for this execution (0 = first try)
  retryCount      Int                  @default(0)
  /// BullMQ job ID for next scheduled retry, null if no retry pending
  retryJobId      String?

  createdAt       DateTime             @default(now())

  @@index([webhookConfigId])
  @@index([webhookConfigId, createdAt])
  @@index([status])
}

/// Dead-letter store for webhook executions that exhausted all retry attempts.
/// Records are written by the webhook trigger route when retryCount >= maxRetries.
/// TODO (Phase 2 — BullMQ): Implement a Worker that periodically reads unprocessed
/// dead-letters, alerts the agent owner, and optionally replays after manual review.
/// Until then this table serves as an audit trail only — no automatic reprocessing.
model WebhookDeadLetter {
  id              String   @id @default(cuid())
  webhookConfigId String
  executionId     String
  eventType       String?
  payload         String?  @db.Text
  headers         Json?
  errorMessage    String?  @db.Text
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([webhookConfigId])
  @@index([createdAt])
}

// ─── Agent Evals / Testing Framework ─────────────────────────────────────────

enum EvalRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EvalResultStatus {
  PENDING
  PASSED
  FAILED
  ERROR
  SKIPPED
}

model EvalSuite {
  id                String         @id @default(cuid())
  name              String
  description       String?
  agentId           String
  agent             Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  testCases         EvalTestCase[]
  runs              EvalRun[]
  isDefault         Boolean        @default(false)
  runOnDeploy       Boolean        @default(false)
  // Scheduled eval runs
  scheduleEnabled   Boolean        @default(false)
  scheduleCron      String?        // cron expression e.g. "0 3 * * *" or "0 3 * * *|Europe/Belgrade" (with TZ suffix)
  lastScheduledAt   DateTime?      // last time this suite was auto-run by schedule
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([agentId])
  @@index([agentId, runOnDeploy])
  @@index([scheduleEnabled])
}

model EvalTestCase {
  id         String       @id @default(cuid())
  suiteId    String
  suite      EvalSuite    @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  label      String
  input      String       @db.Text
  assertions Json                          // EvalAssertion[]
  tags       String[]     @default([])
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  results    EvalResult[]

  @@index([suiteId])
}

model EvalRun {
  id              String        @id @default(cuid())
  suiteId         String
  suite           EvalSuite     @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  status          EvalRunStatus @default(PENDING)
  totalCases      Int           @default(0)
  passedCases     Int           @default(0)
  failedCases     Int           @default(0)
  score           Float?
  durationMs      Int?
  triggeredBy     String?                  // "manual" | "deploy" | "schedule" | "compare"
  results         EvalResult[]
  errorMessage    String?
  createdAt       DateTime      @default(now())
  completedAt     DateTime?
  // Head-to-head comparison fields
  comparisonRunId String?                  // paired run ID for A/B comparison
  flowVersionId   String?                  // which flow version was tested (null = active)
  modelOverride   String?                  // model used if comparing different models

  @@index([suiteId])
  @@index([suiteId, createdAt])
}

model EvalResult {
  id           String           @id @default(cuid())
  runId        String
  run          EvalRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCaseId   String
  testCase     EvalTestCase     @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  status       EvalResultStatus @default(PENDING)
  agentOutput  String?          @db.Text
  assertions   Json                          // AssertionResult[]
  score        Float?
  latencyMs    Int?
  tokensUsed   Json?
  errorMessage String?
  createdAt    DateTime         @default(now())

  @@index([runId])
  @@index([testCaseId])
}

// ─── ECC Foundation ─────────────────────────────────────────────────────────

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
}

model AgentExecution {
  id                String          @id @default(cuid())
  agentId           String
  agent             Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status            ExecutionStatus @default(PENDING)
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  durationMs        Int?
  inputParams       Json?
  outputResult      Json?
  traceId           String?
  parentExecutionId String?
  parentExecution   AgentExecution?  @relation("ExecutionTree", fields: [parentExecutionId], references: [id])
  childExecutions   AgentExecution[] @relation("ExecutionTree")
  error             String?
  tokenUsage        Json?
  createdAt         DateTime        @default(now())

  @@index([agentId, status])
  @@index([traceId])
}

model Skill {
  id           String                 @id @default(cuid())
  name         String
  slug         String                 @unique
  version      String                 @default("1.0.0")
  description  String
  content      String                 @db.Text
  inputSchema  Json?
  outputSchema Json?
  tags         String[]               @default([])
  category     String?
  language     String?
  eccOrigin    Boolean                @default(true)
  permissions  AgentSkillPermission[]
  instincts    Instinct[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([slug])
  @@index([language])
}

enum AccessLevel {
  READ
  EXECUTE
  ADMIN
}

model AgentSkillPermission {
  id          String      @id @default(cuid())
  agentId     String
  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  accessLevel AccessLevel @default(READ)

  @@unique([agentId, skillId])
}

model Instinct {
  id                String   @id @default(cuid())
  name              String
  description       String
  confidence        Float    @default(0.0)
  frequency         Int      @default(1)
  origin            String?
  examples          Json?
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  promotedToSkillId String?
  promotedToSkill   Skill?   @relation(fields: [promotedToSkillId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([agentId, confidence])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String
  before       Json?
  after        Json?
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([userId, timestamp])
}

// ---------------------------------------------------------------------------
// Visual Flow Debugger — Trace Persistence (Phase 5)
// ---------------------------------------------------------------------------

enum TraceStatus {
  RUNNING
  COMPLETED
  FAILED
}

model FlowTrace {
  id              String      @id @default(cuid())
  agentId         String
  agent           Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversationId  String?
  testInput       String?     @db.Text
  status          TraceStatus @default(RUNNING)
  totalDurationMs Int?
  nodesExecuted   Int?
  nodesFailed     Int?
  executionPath   String[]
  nodeTraces      Json        // Map<nodeId, NodeDebugState>
  edgeTraces      Json        // Map<edgeKey, EdgeDebugState>
  flowSummary     Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([agentId, createdAt])
}

// ---------------------------------------------------------------------------
// Multi-tenancy — Organization + RBAC (Phase 2)
// ---------------------------------------------------------------------------

enum PlanTier {
  FREE
  PRO
  TEAM
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Organization {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  plan        PlanTier              @default(FREE)
  members     OrganizationMember[]
  agents      Agent[]               @relation("OrgAgents")
  invitations Invitation[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([slug])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(MEMBER)
  joinedAt       DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(MEMBER)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([email, organizationId])
}
