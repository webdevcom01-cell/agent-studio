# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:password@aws-0-region.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Providers (at least one required)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Optional: Google AI
GOOGLE_GENERATIVE_AI_API_KEY=""

# Auth (NextAuth v5)
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Multi-model support (all optional — add keys to enable providers)
GOOGLE_GENERATIVE_AI_API_KEY=""    # aistudio.google.com — enables Gemini 2.5 Flash/Pro
GROQ_API_KEY=""                    # console.groq.com — enables Llama 3.3, Compound Beta (free tier)
MISTRAL_API_KEY=""                 # console.mistral.ai — enables Mistral Small/Large
MOONSHOT_API_KEY=""                # platform.moonshot.cn — enables Kimi K2
