# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:password@aws-0-region.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Providers — Required
DEEPSEEK_API_KEY=""                # platform.deepseek.com — default chat model
OPENAI_API_KEY=""                  # platform.openai.com — required for embeddings + GPT models

# Auth (NextAuth v5)
AUTH_SECRET=""                     # openssl rand -base64 32
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# AI Providers — Optional (add keys to enable additional models)
ANTHROPIC_API_KEY=""               # console.anthropic.com — enables Claude Haiku/Sonnet/Opus
GOOGLE_GENERATIVE_AI_API_KEY=""    # aistudio.google.com — enables Gemini 2.5 Flash/Pro (free tier available)
GROQ_API_KEY=""                    # console.groq.com — enables Llama 3.3, Compound Beta (free tier)
MISTRAL_API_KEY=""                 # console.mistral.ai — enables Mistral Small/Medium/Large
MOONSHOT_API_KEY=""                # platform.moonshot.cn — enables Kimi K2
