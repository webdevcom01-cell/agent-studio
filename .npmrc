enable-pre-post-scripts=true
manage-package-manager-versions=false

frozen-lockfile=false

# Install native binaries for both macOS and Linux ARM64/x64
# so pnpm test works in Cowork sandbox (Linux ARM64) even when
# node_modules were built on macOS.
supportedArchitectures[os][]=darwin
supportedArchitectures[os][]=linux
supportedArchitectures[cpu][]=arm64
supportedArchitectures[cpu][]=x64
